NODE_ENV=production

APP_URL=https://example.com
ADMIN_URL=https://example.com/admin
API_URL=https://example.com
NEXT_PUBLIC_APP_URL=https://example.com
NEXT_PUBLIC_API_URL=https://example.com
ADMIN_BASE_PATH=/admin

POSTGRES_USER=ai_tool_cms
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=ai_tool_cms
# Optional only when reusing an existing Postgres volume initialized with a different superuser.
POSTGRES_ADMIN_USER=
POSTGRES_ADMIN_PASSWORD=
POSTGRES_ADMIN_DB=postgres
REDIS_PASSWORD=replace-with-strong-redis-password

# Generate with: openssl rand -base64 48
JWT_SECRET=generate-a-unique-48-byte-base64-value-for-access-tokens
# Generate with: openssl rand -base64 48
JWT_REFRESH_SECRET=generate-a-different-48-byte-base64-value-for-refresh-tokens
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_EXPIRES_IN=7d
# Production must be explicit. Do not use "*" or wildcard origins.
CORS_ORIGINS=https://example.com,https://admin.example.com
TRUST_PROXY=true

MEILI_MASTER_KEY=replace-with-strong-meilisearch-key
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=text-embedding-3-small

STORAGE_BUCKET=ai-tool-cms
STORAGE_ACCESS_KEY=replace-with-storage-access-key
# Generate or copy the real MinIO/S3 secret key. Do not use a placeholder.
STORAGE_SECRET_KEY=generate-a-unique-storage-secret-key
STORAGE_REGION=us-east-1

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=replace-with-smtp-user
SMTP_PASSWORD=replace-with-smtp-password
NEWSLETTER_FROM_EMAIL=noreply@example.com
# Generate with: openssl rand -base64 48
WEBHOOK_SIGNING_SECRET=generate-a-unique-48-byte-webhook-signing-secret

OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
AI_DEFAULT_MODEL=gpt-4o-mini

CRAWLER_USER_AGENT=AI-Tool-CMS-Bot/1.0
CRAWLER_CONCURRENCY=5
CRAWLER_TIMEOUT_MS=30000
CRAWLER_ENABLE_PRODUCTION_ADAPTERS=false

LOG_LEVEL=info
SITE_NAME=AI Tool CMS
SITE_DESCRIPTION=AI tools directory CMS
DEFAULT_LOCALE=en
ENABLED_LOCALES=en,zh-CN
FALLBACK_LOCALE=en
NEXT_PUBLIC_ENABLED_LOCALES=en,zh-CN

CDN_PROVIDER=none
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=
R2_BUCKET=
R2_ENDPOINT=
EDGE_CACHE_TTL_SECONDS=3600

OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
CACHE_DEFAULT_TTL_SECONDS=60

IMAGE_REGISTRY=ghcr.io/zhshg
IMAGE_TAG=1.0.0
HTTP_PORT=80
