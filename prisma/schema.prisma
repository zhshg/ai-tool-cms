// =============================================================================
// AI Tool CMS — Prisma Schema v1 (Commit 011)
// Production-grade baseline. Minimize future breaking migrations.
// =============================================================================
//
// Every model MUST include:
//   id (UUID) | createdAt | updatedAt | deletedAt | metadata (JSON)
//   slug (when publicly addressable) | indexes on FKs | soft-delete support
//
// Auditable domain models also include:
//   createdById | updatedById | deletedById (indexed actor UUIDs)
//
// Slug uniqueness among active rows is enforced via partial unique indexes
// in migration SQL (WHERE deleted_at IS NULL). Soft-deleted rows may reuse slugs.
//
// AuditLog is append-only in application code; it still carries standard
// timestamp / metadata fields for schema consistency.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

/// Tool editorial lifecycle (RFC-0001).
enum ToolStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

/// High-level pricing classification on a tool.
enum PricingModel {
  FREE
  FREEMIUM
  PAID
  CONTACT
}

enum BillingPeriod {
  MONTHLY
  YEARLY
  ONE_TIME
  CUSTOM
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  PUBLISHED
}

enum PromptStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum CrawlJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

/// Source registry lifecycle (enable / disable / pause).
enum CrawlSourceStatus {
  ENABLED
  DISABLED
  PAUSED
}

/// Scheduler cadence for automated crawls.
enum CrawlSchedule {
  HOURLY
  DAILY
  WEEKLY
  MANUAL
}

enum CrawlQueueJobType {
  CRAWL_TOOL
  CRAWL_CATEGORY
  CRAWL_DETAIL
  CRAWL_IMAGE
  NORMALIZE
}

enum AiGenerationTaskStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

/// AI-generated content review gate (Commit 039).
enum ContentRevisionStatus {
  PENDING
  APPROVED
  REJECTED
}

/// AI enrichment pipeline stages (Commit 040).
enum AiPipelineStage {
  SUMMARY
  FEATURE
  FAQ
  SEO
  GEO
  QUALITY
  PUBLISH
}

enum ReviewVoteValue {
  UP
  DOWN
}

enum SeoEntityType {
  TOOL
  CATEGORY
  TAG
  PROMPT
  COLLECTION
  PAGE
}

/// Compare / alternatives / top-list SEO pages (Commit 046).
enum SeoComparePageType {
  TOOL_VS
  ALTERNATIVES
  TOP_LIST
}

/// Internal link types for tool pages (Commit 044).
enum InternalLinkType {
  ALTERNATIVE
  COMPARE
  CATEGORY
  TAG
  PROMPT
  FAQ
  RELATED
  TRENDING
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  PUBLISH
  ARCHIVE
  LOGIN
  LOGOUT
  OTHER
}

// -----------------------------------------------------------------------------
// RBAC & Identity
// -----------------------------------------------------------------------------

/// Platform user account.
model User {
  id              String     @id @default(uuid()) @db.Uuid
  email           String     @unique @db.VarChar(320)
  slug            String?    @db.VarChar(120)
  passwordHash    String     @map("password_hash") @db.VarChar(255)
  displayName     String?    @map("display_name") @db.VarChar(120)
  avatarUrl       String?    @map("avatar_url") @db.VarChar(2048)
  status          UserStatus @default(ACTIVE)
  emailVerifiedAt DateTime?  @map("email_verified_at")
  lastLoginAt     DateTime?  @map("last_login_at")
  createdById     String?    @map("created_by_id") @db.Uuid
  updatedById     String?    @map("updated_by_id") @db.Uuid
  deletedById     String?    @map("deleted_by_id") @db.Uuid
  metadata        Json       @default("{}")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  deletedAt       DateTime?  @map("deleted_at")

  roles             UserRole[]
  apiKeys           ApiKey[]
  reviews           Review[]
  reviewVotes       ReviewVote[]
  favorites         Favorite[]
  collections       Collection[]
  auditLogs         AuditLog[]         @relation("AuditActor")
  aiGenerationTasks AiGenerationTask[]

  @@index([status])
  @@index([slug])
  @@index([createdById])
  @@index([updatedById])
  @@index([deletedById])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("users")
}

/// RBAC role (admin, editor, viewer, ...).
model Role {
  id          String    @id @default(uuid()) @db.Uuid
  slug        String    @db.VarChar(64)
  code        String    @unique @db.VarChar(64)
  name        String    @db.VarChar(120)
  description String?   @db.Text
  isSystem    Boolean   @default(false) @map("is_system")
  createdById String?   @map("created_by_id") @db.Uuid
  updatedById String?   @map("updated_by_id") @db.Uuid
  deletedById String?   @map("deleted_by_id") @db.Uuid
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  users       UserRole[]
  permissions RolePermission[]

  @@index([slug])
  @@index([createdById])
  @@index([updatedById])
  @@index([deletedById])
  @@index([deletedAt])
  @@index([updatedAt])
  @@map("roles")
}

/// Atomic permission code (e.g. tools:read).
model Permission {
  id          String    @id @default(uuid()) @db.Uuid
  slug        String    @db.VarChar(128)
  code        String    @unique @db.VarChar(128)
  name        String    @db.VarChar(120)
  description String?   @db.Text
  module      String    @db.VarChar(64)
  createdById String?   @map("created_by_id") @db.Uuid
  updatedById String?   @map("updated_by_id") @db.Uuid
  deletedById String?   @map("deleted_by_id") @db.Uuid
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  roles RolePermission[]

  @@index([slug])
  @@index([module])
  @@index([createdById])
  @@index([updatedById])
  @@index([deletedById])
  @@index([deletedAt])
  @@index([updatedAt])
  @@map("permissions")
}

/// User ↔ Role assignment.
model UserRole {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  roleId    String    @map("role_id") @db.Uuid
  metadata  Json      @default("{}")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@index([deletedAt])
  @@index([updatedAt])
  @@map("user_roles")
}

/// Role ↔ Permission assignment.
model RolePermission {
  id           String    @id @default(uuid()) @db.Uuid
  roleId       String    @map("role_id") @db.Uuid
  permissionId String    @map("permission_id") @db.Uuid
  metadata     Json      @default("{}")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@index([deletedAt])
  @@index([updatedAt])
  @@map("role_permissions")
}

/// Programmatic API access key for a user.
model ApiKey {
  id         String       @id @default(uuid()) @db.Uuid
  userId     String       @map("user_id") @db.Uuid
  name       String       @db.VarChar(120)
  keyPrefix  String       @map("key_prefix") @db.VarChar(16)
  keyHash    String       @map("key_hash") @db.VarChar(255)
  status     ApiKeyStatus @default(ACTIVE)
  scopes     String[]     @default([])
  expiresAt  DateTime?    @map("expires_at")
  lastUsedAt DateTime?    @map("last_used_at")
  metadata   Json         @default("{}")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")
  deletedAt  DateTime?    @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyPrefix])
  @@index([status])
  @@index([deletedAt])
  @@index([updatedAt])
  @@map("api_keys")
}

// -----------------------------------------------------------------------------
// Taxonomy
// -----------------------------------------------------------------------------

/// Hierarchical tool category.
model Category {
  id              String    @id @default(uuid()) @db.Uuid
  slug            String    @db.VarChar(120)
  name            String    @db.VarChar(160)
  description     String?   @db.Text
  parentId        String?   @map("parent_id") @db.Uuid
  sortOrder       Int       @default(0) @map("sort_order")
  iconUrl         String?   @map("icon_url") @db.VarChar(2048)
  metaTitle       String?   @map("meta_title") @db.VarChar(160)
  metaDescription String?   @map("meta_description") @db.VarChar(320)
  createdById     String?   @map("created_by_id") @db.Uuid
  updatedById     String?   @map("updated_by_id") @db.Uuid
  deletedById     String?   @map("deleted_by_id") @db.Uuid
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  parent   Category?      @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[]     @relation("CategoryHierarchy")
  tools    ToolCategory[]
  seoComparePages SeoComparePage[]

  @@index([slug])
  @@index([parentId])
  @@index([sortOrder])
  @@index([createdById])
  @@index([updatedById])
  @@index([deletedById])
  @@index([deletedAt])
  @@index([updatedAt])
  @@map("categories")
}

/// Flat tag for discovery and filtering.
model Tag {
  id          String    @id @default(uuid()) @db.Uuid
  slug        String    @db.VarChar(120)
  name        String    @db.VarChar(120)
  description String?   @db.Text
  createdById String?   @map("created_by_id") @db.Uuid
  updatedById String?   @map("updated_by_id") @db.Uuid
  deletedById String?   @map("deleted_by_id") @db.Uuid
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tools ToolTag[]
  seoComparePages SeoComparePage[]

  @@index([slug])
  @@index([createdById])
  @@index([updatedById])
  @@index([deletedById])
  @@index([deletedAt])
  @@index([updatedAt])
  @@map("tags")
}

// -----------------------------------------------------------------------------
// Tool aggregate (catalog core)
// -----------------------------------------------------------------------------

/// Canonical AI tool catalog entry (RFC-0001).
model Tool {
  id              String       @id @default(uuid()) @db.Uuid
  slug            String       @db.VarChar(120)
  name            String       @db.VarChar(200)
  description     String?      @db.Text
  summary         String?      @db.VarChar(500)
  longDescription String?      @map("long_description") @db.Text
  website         String       @db.VarChar(2048)
  logoUrl         String?      @map("logo_url") @db.VarChar(2048)
  pricingModel    PricingModel @default(FREE) @map("pricing_model")
  status          ToolStatus   @default(DRAFT)
  metaTitle       String?      @map("meta_title") @db.VarChar(160)
  metaDescription String?      @map("meta_description") @db.VarChar(320)
  publishedAt     DateTime?    @map("published_at")
  scheduledAt     DateTime?    @map("scheduled_at")
  createdById     String?      @map("created_by_id") @db.Uuid
  updatedById     String?      @map("updated_by_id") @db.Uuid
  deletedById     String?      @map("deleted_by_id") @db.Uuid
  metadata        Json         @default("{}")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")

  categories        ToolCategory[]
  tags              ToolTag[]
  pricingPlans      PricingPlan[]
  versions          ToolVersion[]
  reviews           Review[]
  faqs              Faq[]
  prompts           Prompt[]
  favorites         Favorite[]
  collectionItems   CollectionItem[]
  seoMetadata       SeoMetadata[]
  aiGenerationTasks AiGenerationTask[]
  contentRevisions  ContentRevision[]
  internalLinks     InternalLink[]     @relation("InternalLinkSource")
  seoComparePages   SeoComparePage[]   @relation("SeoComparePrimaryTool")
  seoComparePagesB  SeoComparePage[]   @relation("SeoCompareSecondaryTool")

  @@index([slug])
  @@index([status])
  @@index([pricingModel])
  @@index([publishedAt])
  @@index([website])
  @@index([createdById])
  @@index([updatedById])
  @@index([deletedById])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("tools")
}

/// Tool ↔ Category (M:N).
model ToolCategory {
  id         String    @id @default(uuid()) @db.Uuid
  toolId     String    @map("tool_id") @db.Uuid
  categoryId String    @map("category_id") @db.Uuid
  isPrimary  Boolean   @default(false) @map("is_primary")
  metadata   Json      @default("{}")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  tool     Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([toolId, categoryId])
  @@index([toolId])
  @@index([categoryId])
  @@index([deletedAt])
  @@index([updatedAt])
  @@map("tool_categories")
}

/// Tool ↔ Tag (M:N).
model ToolTag {
  id        String    @id @default(uuid()) @db.Uuid
  toolId    String    @map("tool_id") @db.Uuid
  tagId     String    @map("tag_id") @db.Uuid
  metadata  Json      @default("{}")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([toolId, tagId])
  @@index([toolId])
  @@index([tagId])
  @@index([deletedAt])
  @@index([updatedAt])
  @@map("tool_tags")
}

/// Structured pricing tier for a tool.
model PricingPlan {
  id            String         @id @default(uuid()) @db.Uuid
  toolId        String         @map("tool_id") @db.Uuid
  slug          String         @db.VarChar(120)
  name          String         @db.VarChar(120)
  pricingModel  PricingModel   @map("pricing_model")
  currency      String         @default("USD") @db.VarChar(3)
  amount        Decimal?       @db.Decimal(12, 2)
  billingPeriod BillingPeriod? @map("billing_period")
  description   String?        @db.Text
  isFeatured    Boolean        @default(false) @map("is_featured")
  sortOrder     Int            @default(0) @map("sort_order")
  createdById   String?        @map("created_by_id") @db.Uuid
  updatedById   String?        @map("updated_by_id") @db.Uuid
  deletedById   String?        @map("deleted_by_id") @db.Uuid
  metadata      Json           @default("{}")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  deletedAt     DateTime?      @map("deleted_at")

  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([toolId, slug])
  @@index([toolId])
  @@index([pricingModel])
  @@index([createdById])
  @@index([updatedById])
  @@index([deletedById])
  @@index([deletedAt])
  @@index([updatedAt])
  @@map("pricing_plans")
}

/// Immutable-style content snapshot for a tool.
model ToolVersion {
  id            String     @id @default(uuid()) @db.Uuid
  toolId        String     @map("tool_id") @db.Uuid
  slug          String     @db.VarChar(120)
  versionNumber Int        @map("version_number")
  status        ToolStatus
  changelog     String?    @db.Text
  snapshot      Json       @default("{}")
  publishedAt   DateTime?  @map("published_at")
  createdById   String?    @map("created_by_id") @db.Uuid
  updatedById   String?    @map("updated_by_id") @db.Uuid
  deletedById   String?    @map("deleted_by_id") @db.Uuid
  metadata      Json       @default("{}")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  deletedAt     DateTime?  @map("deleted_at")

  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([toolId, versionNumber])
  @@index([toolId, slug])
  @@index([toolId])
  @@index([status])
  @@index([createdById])
  @@index([updatedById])
  @@index([deletedById])
  @@index([deletedAt])
  @@index([updatedAt])
  @@map("tool_versions")
}

// -----------------------------------------------------------------------------
// Reviews & engagement
// -----------------------------------------------------------------------------

/// User or editorial review for a tool.
model Review {
  id          String       @id @default(uuid()) @db.Uuid
  toolId      String       @map("tool_id") @db.Uuid
  userId      String?      @map("user_id") @db.Uuid
  slug        String       @db.VarChar(120)
  authorName  String?      @map("author_name") @db.VarChar(120)
  rating      Int
  title       String?      @db.VarChar(200)
  content     String       @db.Text
  status      ReviewStatus @default(PENDING)
  createdById String?      @map("created_by_id") @db.Uuid
  updatedById String?      @map("updated_by_id") @db.Uuid
  deletedById String?      @map("deleted_by_id") @db.Uuid
  metadata    Json         @default("{}")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")

  tool  Tool         @relation(fields: [toolId], references: [id], onDelete: Cascade)
  user  User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  votes ReviewVote[]

  @@index([toolId, slug])
  @@index([toolId])
  @@index([userId])
  @@index([status])
  @@index([rating])
  @@index([createdById])
  @@index([updatedById])
  @@index([deletedById])
  @@index([deletedAt])
  @@index([updatedAt])
  @@map("reviews")
}

/// Up/down vote on a review.
model ReviewVote {
  id        String          @id @default(uuid()) @db.Uuid
  reviewId  String          @map("review_id") @db.Uuid
  userId    String          @map("user_id") @db.Uuid
  value     ReviewVoteValue
  metadata  Json            @default("{}")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  deletedAt DateTime?       @map("deleted_at")

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
  @@index([reviewId])
  @@index([userId])
  @@index([deletedAt])
  @@index([updatedAt])
  @@map("review_votes")
}

/// Tool-specific FAQ entry.
model Faq {
  id          String    @id @default(uuid()) @db.Uuid
  toolId      String    @map("tool_id") @db.Uuid
  slug        String    @db.VarChar(120)
  question    String    @db.VarChar(500)
  answer      String    @db.Text
  sortOrder   Int       @default(0) @map("sort_order")
  createdById String?   @map("created_by_id") @db.Uuid
  updatedById String?   @map("updated_by_id") @db.Uuid
  deletedById String?   @map("deleted_by_id") @db.Uuid
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([toolId, slug])
  @@index([toolId])
  @@index([sortOrder])
  @@index([createdById])
  @@index([updatedById])
  @@index([deletedById])
  @@index([deletedAt])
  @@index([updatedAt])
  @@map("faqs")
}

// -----------------------------------------------------------------------------
// Prompts library
// -----------------------------------------------------------------------------

/// Taxonomy for prompt templates.
model PromptCategory {
  id          String    @id @default(uuid()) @db.Uuid
  slug        String    @db.VarChar(120)
  name        String    @db.VarChar(160)
  description String?   @db.Text
  parentId    String?   @map("parent_id") @db.Uuid
  sortOrder   Int       @default(0) @map("sort_order")
  createdById String?   @map("created_by_id") @db.Uuid
  updatedById String?   @map("updated_by_id") @db.Uuid
  deletedById String?   @map("deleted_by_id") @db.Uuid
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  parent   PromptCategory?  @relation("PromptCategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children PromptCategory[] @relation("PromptCategoryHierarchy")
  prompts  Prompt[]

  @@index([slug])
  @@index([parentId])
  @@index([createdById])
  @@index([updatedById])
  @@index([deletedById])
  @@index([deletedAt])
  @@index([updatedAt])
  @@map("prompt_categories")
}

/// Reusable prompt template, optionally linked to a tool.
model Prompt {
  id               String       @id @default(uuid()) @db.Uuid
  slug             String       @db.VarChar(120)
  title            String       @db.VarChar(200)
  content          String       @db.Text
  status           PromptStatus @default(DRAFT)
  toolId           String?      @map("tool_id") @db.Uuid
  promptCategoryId String?      @map("prompt_category_id") @db.Uuid
  modelHint        String?      @map("model_hint") @db.VarChar(120)
  variables        Json         @default("[]")
  createdById      String?      @map("created_by_id") @db.Uuid
  updatedById      String?      @map("updated_by_id") @db.Uuid
  deletedById      String?      @map("deleted_by_id") @db.Uuid
  metadata         Json         @default("{}")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  deletedAt        DateTime?    @map("deleted_at")

  tool           Tool?           @relation(fields: [toolId], references: [id], onDelete: SetNull)
  promptCategory PromptCategory? @relation(fields: [promptCategoryId], references: [id], onDelete: SetNull)

  @@index([slug])
  @@index([toolId])
  @@index([promptCategoryId])
  @@index([status])
  @@index([createdById])
  @@index([updatedById])
  @@index([deletedById])
  @@index([deletedAt])
  @@index([updatedAt])
  @@map("prompts")
}

// -----------------------------------------------------------------------------
// Collections & favorites
// -----------------------------------------------------------------------------

/// Curated list of tools created by a user.
model Collection {
  id          String    @id @default(uuid()) @db.Uuid
  slug        String    @db.VarChar(120)
  name        String    @db.VarChar(160)
  description String?   @db.Text
  userId      String    @map("user_id") @db.Uuid
  isPublic    Boolean   @default(false) @map("is_public")
  createdById String?   @map("created_by_id") @db.Uuid
  updatedById String?   @map("updated_by_id") @db.Uuid
  deletedById String?   @map("deleted_by_id") @db.Uuid
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CollectionItem[]

  @@index([slug])
  @@index([userId])
  @@index([isPublic])
  @@index([createdById])
  @@index([updatedById])
  @@index([deletedById])
  @@index([deletedAt])
  @@index([updatedAt])
  @@map("collections")
}

/// Tool membership inside a collection.
model CollectionItem {
  id           String    @id @default(uuid()) @db.Uuid
  collectionId String    @map("collection_id") @db.Uuid
  toolId       String    @map("tool_id") @db.Uuid
  sortOrder    Int       @default(0) @map("sort_order")
  note         String?   @db.VarChar(500)
  metadata     Json      @default("{}")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  tool       Tool       @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([collectionId, toolId])
  @@index([collectionId])
  @@index([toolId])
  @@index([deletedAt])
  @@index([updatedAt])
  @@map("collection_items")
}

/// User bookmark for a tool.
model Favorite {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  toolId    String    @map("tool_id") @db.Uuid
  metadata  Json      @default("{}")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([userId, toolId])
  @@index([userId])
  @@index([toolId])
  @@index([deletedAt])
  @@index([updatedAt])
  @@map("favorites")
}

// -----------------------------------------------------------------------------
// SEO
// -----------------------------------------------------------------------------

/// Polymorphic SEO metadata overlay for public entities.
model SeoMetadata {
  id              String        @id @default(uuid()) @db.Uuid
  entityType      SeoEntityType @map("entity_type")
  entityId        String        @map("entity_id") @db.Uuid
  toolId          String?       @map("tool_id") @db.Uuid
  metaTitle       String?       @map("meta_title") @db.VarChar(160)
  metaDescription String?       @map("meta_description") @db.VarChar(320)
  canonicalUrl    String?       @map("canonical_url") @db.VarChar(2048)
  ogImageUrl      String?       @map("og_image_url") @db.VarChar(2048)
  robots          String?       @db.VarChar(120)
  schemaJson      Json          @default("{}") @map("schema_json")
  createdById     String?       @map("created_by_id") @db.Uuid
  updatedById     String?       @map("updated_by_id") @db.Uuid
  deletedById     String?       @map("deleted_by_id") @db.Uuid
  metadata        Json          @default("{}")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")

  tool Tool? @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([entityType, entityId])
  @@index([toolId])
  @@index([entityType])
  @@index([createdById])
  @@index([updatedById])
  @@index([deletedById])
  @@index([deletedAt])
  @@index([updatedAt])
  @@map("seo_metadata")
}

// -----------------------------------------------------------------------------
// Crawler
// -----------------------------------------------------------------------------

/// Registered external source for crawler ingestion (Source Registry).
model CrawlSource {
  id                   String            @id @default(uuid()) @db.Uuid
  slug                 String            @db.VarChar(120)
  name                 String            @db.VarChar(160)
  baseUrl              String            @map("base_url") @db.VarChar(2048)
  adapterType          String            @map("adapter_type") @db.VarChar(64)
  status               CrawlSourceStatus @default(ENABLED)
  crawlIntervalMinutes Int               @default(1440) @map("crawl_interval_minutes")
  schedule             CrawlSchedule     @default(DAILY)
  robotsTxt            String?           @map("robots_txt") @db.Text
  priority             Int               @default(100)
  lastRunAt            DateTime?         @map("last_run_at")
  nextRunAt            DateTime?         @map("next_run_at")
  isEnabled            Boolean           @default(true) @map("is_enabled")
  config               Json              @default("{}")
  createdById          String?           @map("created_by_id") @db.Uuid
  updatedById          String?           @map("updated_by_id") @db.Uuid
  deletedById          String?           @map("deleted_by_id") @db.Uuid
  metadata             Json              @default("{}")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")
  deletedAt            DateTime?         @map("deleted_at")

  jobs CrawlJob[]

  @@index([slug])
  @@index([status])
  @@index([schedule])
  @@index([priority])
  @@index([nextRunAt])
  @@index([lastRunAt])
  @@index([isEnabled])
  @@index([createdById])
  @@index([updatedById])
  @@index([deletedById])
  @@index([deletedAt])
  @@index([updatedAt])
  @@map("crawl_sources")
}

/// Single crawl execution against a source.
model CrawlJob {
  id           String            @id @default(uuid()) @db.Uuid
  sourceId     String            @map("source_id") @db.Uuid
  jobType      CrawlQueueJobType @default(CRAWL_TOOL) @map("job_type")
  status       CrawlJobStatus    @default(PENDING)
  startedAt    DateTime?      @map("started_at")
  finishedAt   DateTime?      @map("finished_at")
  itemsFound   Int            @default(0) @map("items_found")
  itemsCreated Int            @default(0) @map("items_created")
  itemsUpdated Int            @default(0) @map("items_updated")
  errorMessage String?        @map("error_message") @db.Text
  result       Json           @default("{}")
  createdById  String?        @map("created_by_id") @db.Uuid
  updatedById  String?        @map("updated_by_id") @db.Uuid
  deletedById  String?        @map("deleted_by_id") @db.Uuid
  metadata     Json           @default("{}")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  deletedAt    DateTime?      @map("deleted_at")

  source CrawlSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@index([jobType])
  @@index([status])
  @@index([createdById])
  @@index([updatedById])
  @@index([deletedById])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([updatedAt])
  @@map("crawl_jobs")
}

// -----------------------------------------------------------------------------
// AI pipeline
// -----------------------------------------------------------------------------

/// Async AI enrichment / generation job.
model AiGenerationTask {
  id           String                 @id @default(uuid()) @db.Uuid
  taskType     String                 @map("task_type") @db.VarChar(64)
  status       AiGenerationTaskStatus @default(PENDING)
  toolId       String?                @map("tool_id") @db.Uuid
  userId       String?                @map("user_id") @db.Uuid
  model        String?                @db.VarChar(120)
  input        Json                   @default("{}")
  output       Json                   @default("{}")
  errorMessage String?                @map("error_message") @db.Text
  startedAt    DateTime?              @map("started_at")
  finishedAt   DateTime?              @map("finished_at")
  createdById  String?                @map("created_by_id") @db.Uuid
  updatedById  String?                @map("updated_by_id") @db.Uuid
  deletedById  String?                @map("deleted_by_id") @db.Uuid
  metadata     Json                   @default("{}")
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")
  deletedAt    DateTime?              @map("deleted_at")

  tool Tool? @relation(fields: [toolId], references: [id], onDelete: SetNull)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  contentRevisions ContentRevision[]

  @@index([toolId])
  @@index([userId])
  @@index([status])
  @@index([taskType])
  @@index([createdById])
  @@index([updatedById])
  @@index([deletedById])
  @@index([deletedAt])
  @@index([updatedAt])
  @@map("ai_generation_tasks")
}

/// AI-generated content pending human review before applying to Tool (RFC-0003).
model ContentRevision {
  id           String                 @id @default(uuid()) @db.Uuid
  toolId       String                 @map("tool_id") @db.Uuid
  stage        AiPipelineStage
  status       ContentRevisionStatus  @default(PENDING)
  payload      Json                   @default("{}")
  qualityScore Int?                   @map("quality_score")
  reviewNote   String?                @map("review_note") @db.Text
  aiTaskId     String?                @map("ai_task_id") @db.Uuid
  createdById  String?                @map("created_by_id") @db.Uuid
  updatedById  String?                @map("updated_by_id") @db.Uuid
  reviewedById String?                @map("reviewed_by_id") @db.Uuid
  reviewedAt   DateTime?              @map("reviewed_at")
  metadata     Json                   @default("{}")
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")
  deletedAt    DateTime?              @map("deleted_at")

  tool   Tool              @relation(fields: [toolId], references: [id], onDelete: Cascade)
  aiTask AiGenerationTask? @relation(fields: [aiTaskId], references: [id], onDelete: SetNull)

  @@index([toolId])
  @@index([stage])
  @@index([status])
  @@index([qualityScore])
  @@index([aiTaskId])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("content_revisions")
}

// -----------------------------------------------------------------------------
// SEO platform (Commits 041–050)
// -----------------------------------------------------------------------------

/// Programmatic compare / alternatives / list pages.
model SeoComparePage {
  id          String             @id @default(uuid()) @db.Uuid
  slug        String             @db.VarChar(160)
  type        SeoComparePageType
  title       String             @db.VarChar(200)
  toolId      String?            @map("tool_id") @db.Uuid
  toolBId     String?            @map("tool_b_id") @db.Uuid
  categoryId  String?            @map("category_id") @db.Uuid
  tagId       String?            @map("tag_id") @db.Uuid
  status      ToolStatus         @default(DRAFT)
  metadata    Json               @default("{}")
  publishedAt DateTime?          @map("published_at")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  deletedAt   DateTime?          @map("deleted_at")

  tool   Tool?     @relation("SeoComparePrimaryTool", fields: [toolId], references: [id], onDelete: SetNull)
  toolB  Tool?     @relation("SeoCompareSecondaryTool", fields: [toolBId], references: [id], onDelete: SetNull)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tag    Tag?      @relation(fields: [tagId], references: [id], onDelete: SetNull)

  @@unique([slug])
  @@index([type])
  @@index([status])
  @@index([toolId])
  @@index([categoryId])
  @@index([deletedAt])
  @@map("seo_compare_pages")
}

/// Internal links for tool detail pages (min 20 per tool).
model InternalLink {
  id           String           @id @default(uuid()) @db.Uuid
  sourceToolId String           @map("source_tool_id") @db.Uuid
  targetSlug   String           @map("target_slug") @db.VarChar(160)
  targetKind   String           @map("target_kind") @db.VarChar(32)
  linkType     InternalLinkType @map("link_type")
  anchorText   String           @map("anchor_text") @db.VarChar(200)
  href         String           @db.VarChar(2048)
  sortOrder    Int              @default(0) @map("sort_order")
  metadata     Json             @default("{}")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  deletedAt    DateTime?        @map("deleted_at")

  sourceTool Tool @relation("InternalLinkSource", fields: [sourceToolId], references: [id], onDelete: Cascade)

  @@index([sourceToolId])
  @@index([linkType])
  @@index([targetSlug])
  @@index([deletedAt])
  @@map("internal_links")
}

/// Cached SEO health / search console snapshot for dashboard.
model SeoHealthSnapshot {
  id        String   @id @default(uuid()) @db.Uuid
  score     Int
  payload   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("seo_health_snapshots")
}

// -----------------------------------------------------------------------------
// Audit & settings
// -----------------------------------------------------------------------------

/// Immutable audit trail for sensitive actions (append-only in application code).
model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  actorId    String?     @map("actor_id") @db.Uuid
  action     AuditAction
  entityType String      @map("entity_type") @db.VarChar(64)
  entityId   String?     @map("entity_id") @db.Uuid
  entitySlug String?     @map("entity_slug") @db.VarChar(120)
  ipAddress  String?     @map("ip_address") @db.VarChar(64)
  userAgent  String?     @map("user_agent") @db.VarChar(512)
  before     Json?
  after      Json?
  metadata   Json        @default("{}")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  deletedAt  DateTime?   @map("deleted_at")

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([entitySlug])
  @@index([action])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([updatedAt])
  @@map("audit_logs")
}

/// Key-value application settings (site config, feature flags).
model Setting {
  id          String    @id @default(uuid()) @db.Uuid
  key         String    @unique @db.VarChar(128)
  value       Json
  group       String    @default("general") @db.VarChar(64)
  description String?   @db.Text
  isPublic    Boolean   @default(false) @map("is_public")
  createdById String?   @map("created_by_id") @db.Uuid
  updatedById String?   @map("updated_by_id") @db.Uuid
  deletedById String?   @map("deleted_by_id") @db.Uuid
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([group])
  @@index([isPublic])
  @@index([createdById])
  @@index([updatedById])
  @@index([deletedById])
  @@index([deletedAt])
  @@index([updatedAt])
  @@map("settings")
}
