{
  "name": "@ai-tool-cms/recommendation",
  "version": "0.0.0",
  "private": true,
  "description": "Recommendation Engine — related tools, homepage sections",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint \"src/**/*.ts\" --config ../../eslint.config.mjs",
    "test": "vitest run --config ../../vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-tool-cms/database": "workspace:*",
    "@ai-tool-cms/ranking": "workspace:*",
    "@ai-tool-cms/search": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^6.0.3"
  }
}
