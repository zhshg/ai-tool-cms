{
  "name": "@ai-tool-cms/growth",
  "version": "0.0.0",
  "private": true,
  "description": "Site Growth Loop — auto-expand SEO/GEO, taxonomy, links, and search pings when tools publish",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint \"src/**/*.ts\" --config ../../eslint.config.mjs",
    "test": "vitest run --config ../../vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-tool-cms/api-platform": "workspace:*",
    "@ai-tool-cms/plugins": "workspace:*",
    "@ai-tool-cms/workflow": "workspace:*",
    "@ai-tool-cms/i18n": "workspace:*",
    "@ai-tool-cms/common": "workspace:*",
    "@ai-tool-cms/config": "workspace:*",
    "@ai-tool-cms/database": "workspace:*",
    "@ai-tool-cms/geo": "workspace:*",
    "@ai-tool-cms/queue": "workspace:*",
    "@ai-tool-cms/search": "workspace:*",
    "@ai-tool-cms/seo": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^6.0.3"
  }
}
