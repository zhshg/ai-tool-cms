{
  "name": "@ai-tool-cms/queue",
  "version": "0.0.0",
  "private": true,
  "description": "BullMQ queue definitions for crawler platform",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint \"src/**/*.ts\" --config ../../eslint.config.mjs",
    "test": "vitest run --passWithNoTests --config ../../vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-tool-cms/config": "workspace:*",
    "bullmq": "^5.34.10",
    "ioredis": "^5.11.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^6.0.3"
  }
}
