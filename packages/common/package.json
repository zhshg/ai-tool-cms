{
  "name": "@ai-tool-cms/common",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint \"src/**/*.ts\" --config ../../eslint.config.mjs",
    "test": "vitest run --passWithNoTests --config ../../vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-tool-cms/types": "workspace:*",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
