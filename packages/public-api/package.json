{
  "name": "@ai-tool-cms/public-api",
  "version": "1.0.0-rc.1",
  "private": true,
  "description": "Public API v1 data layer — tools, search, compare, categories (Commit 091)",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint \"src/**/*.ts\" --config ../../eslint.config.mjs",
    "test": "vitest run --config ../../vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-tool-cms/database": "workspace:*",
    "@ai-tool-cms/ranking": "workspace:*",
    "@ai-tool-cms/recommendation": "workspace:*",
    "@ai-tool-cms/search": "workspace:*",
    "@ai-tool-cms/seo": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.3"
  }
}
