{
  "name": "@ai-tool-cms/database",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:seed": "pnpm --filter @ai-tool-cms/auth build && pnpm --filter @ai-tool-cms/common build && prisma db seed",
    "build": "pnpm db:generate && tsc -p tsconfig.build.json",
    "lint": "eslint \"src/**/*.ts\" --config ../../eslint.config.mjs",
    "test": "vitest run --passWithNoTests --config ../../vitest.config.ts",
    "typecheck": "pnpm db:generate && tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-tool-cms/config": "workspace:*",
    "@prisma/client": "^7.8.0"
  },
  "devDependencies": {
    "@ai-tool-cms/auth": "workspace:*",
    "@ai-tool-cms/common": "workspace:*",
    "@types/node": "^22.10.0",
    "prisma": "^6.19.3",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
