{
  "name": "@ai-tool-cms/ai",
  "version": "0.0.0",
  "private": true,
  "description": "LLM provider abstraction, routing, and safety filters for AI Tool CMS",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && cp -r prompts dist/",
    "lint": "eslint \"src/**/*.ts\" --config ../../eslint.config.mjs",
    "test": "vitest run --config ../../vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-tool-cms/config": "workspace:*",
    "@ai-tool-cms/logger": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.3"
  }
}
