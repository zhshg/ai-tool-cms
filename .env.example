# ===========================================
# AI Tool CMS 环境变量示例
# 复制为 .env 后填入实际值
# ===========================================

# 应用
NODE_ENV=development
APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
API_URL=http://localhost:4000

# 数据库
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=ai_tool_cms
POSTGRES_PORT=5432
DATABASE_URL=postgresql://user:password@localhost:5432/ai_tool_cms

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Meilisearch
MEILI_ENV=development
MEILI_MASTER_KEY=masterKey
MEILI_NO_ANALYTICS=true
MEILI_PORT=7700
MEILI_HOST=http://localhost:7700
MEILI_SEARCH_KEY=

# 认证
JWT_SECRET=your-jwt-secret
JWT_EXPIRES_IN=7d

# 对象存储（S3 兼容）
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=ai-tool-cms
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=us-east-1

# AI 服务
OPENAI_API_KEY=
OPENAI_BASE_URL=
AI_DEFAULT_MODEL=gpt-4o-mini

# 爬虫
CRAWLER_USER_AGENT=AI-Tool-CMS-Bot/1.0
CRAWLER_CONCURRENCY=5
CRAWLER_TIMEOUT_MS=30000

# 消息队列
QUEUE_URL=redis://localhost:6379/1

# 日志
LOG_LEVEL=debug

# SEO / 站点
SITE_NAME=AI Tool CMS
SITE_DESCRIPTION=
DEFAULT_LOCALE=zh-CN
