# ===========================================
# AI Tool CMS 环境变量示例
# 复制为 .env 后填入实际值
# ===========================================

# 应用
NODE_ENV=development
APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_MOCK_ROLE=admin

# API
PORT=4000

# 数据库
DATABASE_URL=postgresql://user:password@localhost:5432/ai_tool_cms

# Redis
REDIS_URL=redis://localhost:6379

# Search (Meilisearch)
MEILI_URL=http://localhost:7700

# 认证
JWT_SECRET=your-jwt-secret-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-jwt-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d
JWT_EXPIRES_IN=7d

# Seed（Commit 012 / 020）
SEED_ADMIN_EMAIL=admin@ai-tool-cms.local
SEED_ADMIN_PASSWORD=Admin123!
SEED_PROFILE=demo

# 对象存储（S3 兼容 / MinIO）
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=ai-tool-cms
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_REGION=us-east-1

# 邮件（Mailpit 开发环境）
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
MAILPIT_URL=http://localhost:8025

# AI 服务
OPENAI_API_KEY=
OPENAI_KEY=
OPENAI_BASE_URL=
GEMINI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
AI_DEFAULT_MODEL=gpt-4o-mini

# 爬虫
CRAWLER_USER_AGENT=AI-Tool-CMS-Bot/1.0
CRAWLER_CONCURRENCY=5
CRAWLER_TIMEOUT_MS=30000
# 设为 true 时启用 Toolify / Futurepedia / TAAFT 等生产适配器（默认仅 mock）
CRAWLER_ENABLE_PRODUCTION_ADAPTERS=false

# 消息队列
QUEUE_URL=redis://localhost:6379/1

# 日志
LOG_LEVEL=debug

# SEO / 站点
SITE_NAME=AI Tool CMS
SITE_DESCRIPTION=
DEFAULT_LOCALE=zh-CN
