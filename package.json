{
  "name": "ai-tool-cms",
  "version": "1.0.0",
  "private": true,
  "description": "AI 工具内容管理系统 Monorepo",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:local": "node scripts/dev-local.mjs",
    "dev:stack": "turbo run dev --filter=@ai-tool-cms/web --filter=@ai-tool-cms/api",
    "dev:web": "pnpm --filter @ai-tool-cms/web dev",
    "dev:api": "pnpm --filter @ai-tool-cms/api dev",
    "dev:admin": "pnpm --filter @ai-tool-cms/admin dev",
    "dev:ui": "turbo run dev --filter=@ai-tool-cms/web --filter=@ai-tool-cms/admin",
    "db:generate": "pnpm --filter @ai-tool-cms/database db:generate",
    "db:migrate": "pnpm --filter @ai-tool-cms/database db:migrate",
    "db:migrate:deploy": "pnpm --filter @ai-tool-cms/database db:migrate:deploy",
    "db:studio": "pnpm --filter @ai-tool-cms/database db:studio",
    "db:seed": "pnpm --filter @ai-tool-cms/database db:seed",
    "mcp": "pnpm --filter @ai-tool-cms/mcp-server build && pnpm --filter @ai-tool-cms/mcp-server start",
    "mcp:dev": "pnpm --filter @ai-tool-cms/mcp-server dev",
    "setup:env": "node scripts/setup-env.mjs",
    "docker:up": "docker compose up -d --wait",
    "docker:down": "docker compose down",
    "docker:prod:config": "docker compose --env-file .env.production -f docker-compose.prod.yml config",
    "docker:prod:up": "docker compose --env-file .env.production -f docker-compose.prod.yml up -d --wait",
    "docker:prod:down": "docker compose --env-file .env.production -f docker-compose.prod.yml down",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint-staged": "lint-staged",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:unit": "vitest run --config vitest.config.ts tests/unit packages",
    "test:integration": "vitest run --config vitest.config.ts tests/integration",
    "test:e2e": "playwright test -c tests/playwright.config.ts",
    "audit:prod": "node scripts/audit/production-audit.mjs",
    "backup:postgres": "bash scripts/backup/backup-postgres.sh",
    "backup:verify": "bash scripts/backup/verify-backup.sh",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "@playwright/test": "^1.49.1",
    "turbo": "^2.4.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.18.0",
    "vitest": "^3.0.5"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
