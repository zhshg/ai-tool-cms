{
  "name": "ai-tool-cms",
  "version": "0.0.0",
  "private": true,
  "description": "AI 工具内容管理系统 Monorepo",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @ai-tool-cms/web dev",
    "dev:admin": "pnpm --filter @ai-tool-cms/admin dev",
    "dev:api": "pnpm --filter @ai-tool-cms/api dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio --schema prisma/schema.prisma",
    "postinstall": "prisma generate --schema prisma/schema.prisma"
  },
  "devDependencies": {
    "prisma": "^6.19.3",
    "tsx": "^4.19.2",
    "turbo": "^2.4.4",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@ai-tool-cms/database": "workspace:*",
    "@ai-tool-cms/auth": "workspace:*",
    "@prisma/client": "^6.19.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
